{
  "name": "uelfy-clinical",
  "version": "0.2.1",
  "private": true,
  "description": "Uelfy — B2B cardio-nephro-metabolic clinical risk assessment and longitudinal patient monitoring platform.",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "typecheck:prod": "tsc --noEmit --project tsconfig.prod.check.json",
    "inject:public-config": "node scripts/inject-public-config.mjs",
    "build": "node scripts/inject-public-config.mjs",
    "build:check": "node scripts/inject-public-config.mjs && tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "pdf-lib": "^1.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vercel/node": "^3.2.0",
    "typescript": "5.5.4",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "clinical",
    "cardiometabolic",
    "risk-assessment",
    "supabase",
    "b2b"
  ],
  "license": "UNLICENSED"
}
