# =============================================================================
# Uelfy Clinical — .gitignore
# =============================================================================
# Purpose: keep secrets, build artefacts and local noise out of version control.
# Any secret leak is a compliance incident (health-related data processor).
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets / env
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Build output (generated by scripts/inject-public-config.mjs)
# -----------------------------------------------------------------------------
frontend-dist/

# -----------------------------------------------------------------------------
# Legacy 3D assets (Three.js / GLTFLoader) — consumer-wellness leftovers from
# the pre-B2B refactor. Audit AUD-2026-05-04 finding A-01: not deployed
# (vercel.json outputDirectory='frontend-dist'), but committed in repo.
# Operator MUST run `git rm -rf build/` once on a writable workspace; this
# entry prevents the directory from being re-added accidentally afterwards.
# -----------------------------------------------------------------------------
build/

# -----------------------------------------------------------------------------
# Legacy archive — preserved out of git via README.md but excluded from CI.
# -----------------------------------------------------------------------------
_archive_legacy/

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Editors / OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Tool caches
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache/
.tsbuildinfo
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Supabase local CLI
# -----------------------------------------------------------------------------
supabase/.branches/
supabase/.temp/

# -----------------------------------------------------------------------------
# Vendored font binaries (fetched at build time by scripts/fetch-noto-fonts.mjs).
# The TTFs are SIL OFL 1.1 licensed; keep them out of VCS to avoid the extra
# megabytes on every clone and to avoid licence-in-repo ambiguity.
# -----------------------------------------------------------------------------
backend/src/assets/fonts/*.ttf
backend/src/assets/fonts/*.otf
backend/src/assets/fonts/*.download
