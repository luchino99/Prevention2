{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": [],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": [
    "types/**/*.d.ts",
    "backend/**/*.ts",
    "shared/**/*.ts",
    "api/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".build",
    "_legacy_archive",
    "engine/**/*.js",
    "tests/**/*.ts"
  ]
}
